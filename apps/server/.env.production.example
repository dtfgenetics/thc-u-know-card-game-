# THC U Know server production settings

NODE_ENV=production
PORT=5174

# Comma-separated production origins allowed to connect through CORS/Socket.IO.
WEB_ORIGIN=https://dtfseeds.com,https://www.dtfseeds.com,https://games.dtfseeds.com,http://localhost:5173

# First small public test can use memory, but sessions disappear on restart.
SESSION_STORE=memory
SESSION_TTL_SECONDS=86400

# Use Redis for stable public launch.
# SESSION_STORE=redis
# REDIS_URL=redis://default:password@host:6379

# Only true when Redis is configured and multiple Node server processes are running.
ENABLE_REDIS_ADAPTER=false
